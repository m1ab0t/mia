{
  "name": "mia",
  "version": "2.0.1",
  "description": "Mia - Token-efficient AI coding agent powered by Claude",
  "main": "dist/index.js",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/m1ab0t/mia.git"
  },
  "homepage": "https://github.com/m1ab0t/mia",
  "bugs": {
    "url": "https://github.com/m1ab0t/mia/issues"
  },
  "bin": {
    "mia": "./dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "build": "node scripts/build.mjs && tsc --emitDeclarationOnly",
    "debug": "MIA_DEBUG=1 tsx --inspect src/daemon/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint --fix ."
  },
  "keywords": [
    "ai",
    "agent",
    "coding",
    "assistant",
    "mobile",
    "cli",
    "developer",
    "p2p",
    "peer-to-peer",
    "daemon",
    "claude",
    "anthropic",
    "gemini",
    "codex",
    "opencode",
    "hyperswarm",
    "typescript"
  ],
  "author": "m1ab0t",
  "license": "BSL-1.1",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@clack/prompts": "^1.0.1",
    "@opencode-ai/sdk": "^1.2.10",
    "b4a": "^1.7.3",
    "better-sqlite3": "^11.9.1",
    "cronstrue": "^3.12.0",
    "dotenv": "^17.3.1",
    "hyperdb": "^6.0.0",
    "hyperswarm": "^4.17.0",
    "node-cron": "^4.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "qrcode-terminal": "^0.12.0",
    "tiktoken": "^1.0.22",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.6.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "esbuild": "^0.25.0",
    "eslint": "^10.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "tsx": "^4.7.0",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}